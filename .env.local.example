# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Resend API Key (already configured)
RESEND_API_KEY=YOUR_RESEND_API_KEY

# Admin Password Hash (bcrypt)
# Generate: node -e "const bcrypt=require('bcryptjs'); bcrypt.hash('YourPassword', 12).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=YOUR_BCRYPT_HASH

# Stripe Keys (for checkout)
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Site URL (for checkout redirects)
NEXT_PUBLIC_SITE_URL=https://blancographics.xyz

# ===========================================
# ADMIN SECURITY (NEW - Required for v2)
# ===========================================

# Secret admin URL slug (random hex, generated at setup)
# This replaces the old /admin route
# Example: bd62fc87509ca → yoursite.com/bd62fc87509ca
# Generate with: node -e "console.log(require('crypto').randomBytes(12).toString('hex'))"
ADMIN_SECRET_URL=generate-random-slug-here

# IP addresses allowed to access the admin panel (comma-separated)
# Get your public IP from: https://whatismyipaddress.com
# Leave empty to allow all IPs (dev mode only - set this in production!)
# Example: "123.456.78.90,987.65.43.21"
ADMIN_ALLOWED_IPS=""

# Emergency master password for disaster recovery
# Use a strong, unique password
# If you lose access to the admin panel, use /admin-emergency with this password
ADMIN_MASTER_PASSWORD=generate-strong-password-here
